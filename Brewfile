# Runtime + tool dependencies for this dotfiles repo.
# Consumed by `brew bundle` (invoked from install.sh).

# Editor
brew "neovim"

# Required by nvim-treesitter main branch to compile parsers locally
brew "tree-sitter"

# Used by telescope and live grep
brew "ripgrep"
brew "fd"

# Mason-installed LSPs need a Node/Python/Rust toolchain
brew "node"
brew "python"
brew "rustup"

# Shell tooling
brew "tmux"

# Terminal emulators (casks; comment out the ones you don't use)
cask "kitty"
cask "alacritty"
cask "ghostty"

# Nerd Font for completion menu icons and diagnostic glyphs
cask "font-jetbrains-mono-nerd-font"
